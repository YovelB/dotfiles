{
  "init project": {
    "prefix": "init",
    "body": [
      "#set page(margin: 5%)",
      "#set text(font: \"New Computer Modern\", size: 11pt)",
      "#set heading(numbering: \"1.1.\")",
      "",
      "= ${1:Title}",
      "",
      "$0"
    ],
    "description": "init document"
  },
  "figure": {
    "prefix": "fig",
    "body": [
      "#figure(",
      "  image(\"${1:path/to/image.png}\", width: ${2:80%}),",
      "  caption: [${3:Caption}]",
      ") <${4:label}>",
      "$0"
    ],
    "description": "insert a figure"
  },
  "code block": {
    "prefix": "code",
    "body": [
      "```${1:python}",
      "$0",
      "```"
    ],
    "description": "insert code block"
  },
  "inline math": {
    "prefix": "mt",
    "body": [
      "$${1}$"
    ],
    "description": "inline math"
  },
  "block math": {
    "prefix": "mmt",
    "body": [
      "$",
      "  ${1}",
      "$$0"
    ],
    "description": "multiline math block"
  },
  "center align": {
    "prefix": "cent",
    "body": [
      "#align(center)[",
      "  ${1}",
      "]$0"
    ],
    "description": "center alignment block"
  },
  "table": {
    "prefix": "table",
    "body": [
      "#table(",
      "  columns: (${1:1fr}, ${2:1fr}),",
      "  inset: 10pt,",
      "  align: horizon,",
      "  [${3:Header 1}], [${4:Header 2}],",
      "  [${5:Content 1}], [${6:Content 2}]",
      ")"
    ],
    "description": "basic table"
  }
}
