{
  "Initial Article Config": {
    "prefix": "initcfg",
    "body": [
      "\\documentclass[a4paper,11pt]{article}",
      "",
      "% required packages",
      "\\usepackage{times}        % Times for text",
      "\\usepackage{amsmath}      % advanced math formatting",
      "\\usepackage{amssymb}      % mathematical symbols",
      "\\usepackage{physics}      % physics notation",
      "\\usepackage{siunitx}      % SI units",
      "\\usepackage{xcolor}       % colored text",
      "\\usepackage{microtype}    % better typography",
      "\\usepackage{graphicx}     % graphics support",
      "\\usepackage[colorlinks=true, linkcolor=blue, urlcolor=blue, citecolor=blue]{hyperref} % hyperlinks",
      "\\usepackage[margin=1cm,nohead,nofoot]{geometry}",
      "",
      "% resolve siunitx-physics conflict",
      "\\AtBeginDocument{\\RenewCommandCopy\\qty\\SI}",
      "",
      "% globally disable paragraph indentation",
      "\\setlength{\\parindent}{0pt}",
      "",
      "% globally disable underfull hbox warnings",
      "\\hbadness=10000",
      "",
      "\\begin{document}",
      "",
      "% PAGE 1",
      "{\\LARGE\\bfseries Stackup config}",
      "",
      "\\end{document}"
    ],
    "description": "Initial LaTeX article configuration with common packages"
  },
  "Tight Subsection Spacing": {
    "prefix": "subsecspace",
    "body": [
      "% tighter section & subsection spacing",
      "\\makeatletter",
      "\\renewcommand{\\section}{%",
      "  \\@startsection{subsection}{2}{\\z@}%",
      "    {0.5em} % space before",
      "    {0.5em} % space after",
      "    {\\normalfont\\large\\bfseries}}",
      "",
      "\\renewcommand{\\subsection}{%",
      "  \\@startsection{subsubsection}{3}{\\z@}%",
      "    {0.5em} % space before",
      "    {0.5em} % space after",
      "    {\\normalfont\\normalsize\\bfseries}}",
      "\\makeatother"
    ],
    "description": "Tight section and subsection spacing macro"
  }
}
