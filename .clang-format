---
BasedOnStyle: LLVM
Language: C

# indentation
IndentWidth: 2
TabWidth: 2
UseTab: Never
IndentCaseLabels: true

# array/struct packing
AlignArrayOfStructures: Left
BinPackArguments: false
BinPackParameters: false
Cpp11BracedListStyle: true

# alignment - needed for register maps and config tables
AlignConsecutiveAssignments: true
AlignConsecutiveBitFields: true
AlignConsecutiveDeclarations: true
AlignConsecutiveMacros: true
AlignTrailingComments: true
# QualifierAlignment: right

# preprocessor - helps with nested #ifdefs in drivers/HALs
IndentPPDirectives: AfterHash

# line length
ColumnLimit: 100

# braces - K&R style common in embedded/RTOS
BreakBeforeBraces: Linux
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
IndentWrappedFunctionNames: true

# pointers - align right for embedded C convention
PointerAlignment: Right
DerivePointerAlignment: false

# spacing
SpaceAfterCStyleCast: true
SpaceBeforeParens: ControlStatements

# includes
SortIncludes: true
IncludeBlocks: Regroup

# comments
ReflowComments: false

# stm32 attribute macros
# AttributeMacros:
#   - '__RAM_D1'
#   - '__RAM_D2'
#   - '__RAM_D3'
#   - '__ALIGN_BEGIN'
#   - '__ALIGN_END'
#   - '__IO'
#   - '__I'
#   - '__O'

# statement macros - prevents indentation issues with common HAL/CMSIS macros
# StatementMacros:
#   - 'UNUSED'
#   - 'HAL_LOCK'
#   - 'HAL_UNLOCK'
#   - 'WRITE_REG'
#   - 'MODIFY_REG'
#   - 'READ_REG'
#   - 'SET_BIT'
#   - 'CLEAR_BIT'
#   - 'READ_BIT'

---
