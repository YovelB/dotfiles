# User specific config file
# additonal config can be placed at ~/.config/git/config file for additonal configuration

[credential "https://github.com"]
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = !/usr/bin/gh auth git-credential

[user]
	name = yovelb
	email = yovelb2j@proton.me
	signingkey = 6FFFAD675778032F

[alias]
    st = status
    ci = commit

[pull]
    rebase = false

[push]
    default = simple

[init]
    defaultBranch = main

[core]
	symlinks = true
	pager = delta

[commit]
	gpgsign = true

[tag]
	gpgSign = true

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true  # use n and N to move between diff sections
  dark = true
  theme = "Monokai Extended"
  side-by-side = false

[merge]
  conflictStyle = zdiff3
